{
  "server": {
    "host": "0.0.0.0",
    "port": 80,
    "tls": false,
    "cert_file": "",
    "key_file": ""
  },
  "auth": {
    "enabled": true,
    "root_user": "root",
    "root_password": "admin",
    "jwt_secret": "cambiami-con-32-byte-da-openssl-rand",
    "session_ttl": "24h"
  },
  "filesystem": {
    "allowed_prefixes": [
      "/home",
      "/var/www",
      "/mnt",
      "/tmp",
      "/opt"
    ],
    "max_upload_size": 100
  },
  "log": {
    "level": "info",
    "file": "/var/log/webui.log"
  },
  "system": {
    "platform": "auto"
  },
  "ui": {
    "memory_unit": "MB",
    "language": "en"
  },
  "apps_dir": "/usr/local/webui/apps",
  "app_user": "opencasa",
  "app_password": "123456",
  "master_key": ""
}
