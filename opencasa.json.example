{
  "server": {
    "host": "0.0.0.0",
    "port": 80
  },
  "auth": {
    "enabled": true,
    "root_user": "root",
    "root_password": "admin",
    "jwt_secret": "JWT_SECRET_PLACEHOLDER",
    "session_ttl": "24h"
  },
  "filesystem": {
    "allowed_prefixes": ["/home/opencasa"],
    "max_upload_size": 100
  },
  "log": {
    "level": "info",
    "file": "/var/log/webui.log",
    "max_size": 5242880,
    "backup_count": 3
  },
  "system": {
    "platform": "auto",
    "network_interface": ""
  },
  "ui": {
    "memory_unit": "MB",
    "language": "en"
  },
  "apps_dir": "/usr/local/webui/apps",
  "app_user": "opencasa",
  "apps": {
    "max_processes": 10,
    "ports": {},
    "port_pool": [19000,19001,19002,19003,19004,19005,19006,19007,19008,19009]
  },
  "master_key": ""
}
